<%- include("../partials/header") %>

    <div class="card">
        <div class="card-header">
            <h1 class="card-title">🛍️ Sản phẩm của chúng tôi</h1>
        </div>

        <!-- Filter Bar -->
        <div class="filter-bar">
            <form method="GET" class="filter-form">
                <div class="form-group" style="margin-bottom: 0;">
                    <label class="form-label">Tìm kiếm</label>
                    <input type="text" name="keyword" class="form-control" value="<%= filters.keyword %>" placeholder="Tên sản phẩm...">
                </div>

                <div class="form-group" style="margin-bottom: 0;">
                    <label class="form-label">Danh mục</label>
                    <select name="category" class="form-control">
                    <option value="">Tất cả</option>
                    <% categories.forEach(cat => { %>
                        <option value="<%= cat.categoryId %>" 
                                <%= filters.categoryId === cat.categoryId ? 'selected' : '' %>>
                            <%= cat.name %>
                        </option>
                    <% }) %>
                </select>
                </div>

                <div class="form-group" style="margin-bottom: 0;">
                    <label class="form-label">Giá từ</label>
                    <input type="number" name="minPrice" class="form-control" value="<%= filters.minPrice %>" placeholder="0">
                </div>

                <div class="form-group" style="margin-bottom: 0;">
                    <label class="form-label">Giá đến</label>
                    <input type="number" name="maxPrice" class="form-control" value="<%= filters.maxPrice %>" placeholder="999999">
                </div>

                <div class="filter-actions">
                    <button type="submit" class="btn btn-primary">🔍 Tìm</button>
                    <a href="/shop" class="btn btn-secondary">Xóa lọc</a>
                </div>
            </form>
        </div>

        <% if (products.length === 0) { %>
            <div class="empty-state">
                <h3>Không tìm thấy sản phẩm</h3>
                <p>Thử thay đổi bộ lọc</p>
            </div>
            <% } else { %>
                <div class="product-grid">
                    <% products.forEach(p => { %>
                        <div class="product-card fade-in">
                            <% if (p.url_image) { %>
                                <img src="<%= p.url_image %>" alt="<%= p.name %>" class="product-image">
                                <% } else { %>
                                    <div class="product-image" style="display: flex; align-items: center; justify-content: center; font-size: 4rem;">📦</div>
                                    <% } %>

                                        <div class="product-body">
                                            <h3 class="product-title">
                                                <%= p.name %>
                                            </h3>
                                            <div class="product-price">
                                                <%= p.price.toLocaleString('vi-VN') %>₫</div>

                                            <div class="product-stock">
                                                <span class="status-badge status-<%= p.stockStatus.class %>">
                                <%= p.stockStatus.label %>
                            </span>
                                            </div>

                                            <% if (p.quantity > 0) { %>
                                                <div class="product-actions">
                                                    <a href="/shop/product/<%= p.id %>" class="btn btn-primary" style="flex: 1;">👁️ Xem</a>
                                                    <% if (!isStaff) { %>
                                                        <form method="POST" action="/shop/cart/add" style="flex: 1;">
                                                            <input type="hidden" name="productId" value="<%= p.id %>">
                                                            <input type="hidden" name="quantity" value="1">
                                                            <button type="submit" class="btn btn-success" style="width: 100%;">🛒 Thêm</button>
                                                        </form>
                                                    <% } %>
                                                </div>
                                            <% } else { %>
                                                    <button class="btn btn-secondary" disabled style="width: 100%;">Hết hàng</button>
                                                    <% } %>
                                        </div>
                        </div>
                        <% }) %>
                </div>

                <div style="margin-top: 2rem; text-align: center; color: #6b7280;">
                    Hiển thị <strong><%= products.length %></strong> sản phẩm
                </div>
                <% } %>
    </div>

    <%- include("../partials/footer") %>