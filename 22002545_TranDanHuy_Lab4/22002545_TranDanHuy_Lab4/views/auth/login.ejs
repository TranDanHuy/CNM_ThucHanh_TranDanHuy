<%- include("../partials/header") %>

    <div class="auth-container">
        <div class="auth-card">
            <div class="auth-header">
                <h1>🔐 Đăng nhập</h1>
                <p>Đăng nhập để quản lý hệ thống</p>
            </div>

            <form method="POST" action="/auth/login">
                <div class="form-group">
                    <label class="form-label">Tên đăng nhập</label>
                    <input type="text" name="username" class="form-control" required autofocus>
                </div>

                <div class="form-group">
                    <label class="form-label">Mật khẩu</label>
                    <input type="password" name="password" class="form-control" required>
                </div>

                <button type="submit" class="btn btn-primary" style="width: 100%;">Đăng nhập</button>
            </form>

            <div class="auth-links">
                <p>Chưa có tài khoản? <a href="/auth/register">Đăng ký ngay</a></p>
                <p><a href="/shop">← Quay lại trang chủ</a></p>
            </div>

            <div style="margin-top: 2rem; padding-top: 2rem; border-top: 1px solid var(--border-color); text-align: center; color: #6b7280; font-size: 0.875rem;">
                <p><strong>Tài khoản mặc định:</strong></p>
                <p>Admin: admin / admin123</p>
            </div>
        </div>
    </div>

    <%- include("../partials/footer") %>