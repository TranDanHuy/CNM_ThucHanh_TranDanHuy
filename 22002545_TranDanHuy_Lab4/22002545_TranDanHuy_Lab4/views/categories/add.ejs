<%- include("../partials/header") %>

    <div class="card">
        <div class="card-header">
            <h1 class="card-title">➕ Thêm Danh mục</h1>
            <a href="/categories" class="btn btn-secondary">← Quay lại</a>
        </div>

        <form method="POST" action="/categories/add">
            <div class="form-group">
                <label class="form-label">Tên danh mục *</label>
                <input type="text" name="name" class="form-control" required autofocus placeholder="Ví dụ: Điện thoại">
            </div>

            <div class="form-group">
                <label class="form-label">Mô tả</label>
                <textarea name="description" class="form-control" rows="4" placeholder="Mô tả về danh mục này..."></textarea>
            </div>

            <div class="btn-group">
                <button type="submit" class="btn btn-success">✅ Thêm danh mục</button>
                <a href="/categories" class="btn btn-secondary">Hủy</a>
            </div>
        </form>
    </div>

    <%- include("../partials/footer") %>