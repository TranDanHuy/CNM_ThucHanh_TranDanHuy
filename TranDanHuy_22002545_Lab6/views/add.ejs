<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <title>Thêm sản phẩm</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background-color: #f0f2f5;
        }
        
        .form-card {
            background: white;
            border-radius: 15px;
            border: 1px solid #adb5bd;
            padding: 40px;
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.05);
        }
        
        .form-control {
            border: 1px solid #ced4da;
            padding: 12px;
        }
        
        .btn-save {
            background-color: #1a237e;
            color: white;
        }
    </style>
</head>

<body>
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-md-6 form-card">
                <h3 class="text-center fw-bold mb-4">Thêm sản phẩm mới</h3>
                <form action="/add" method="POST" enctype="multipart/form-data">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Tên sản phẩm</label>
                        <input type="text" name="name" class="form-control" required>
                    </div>
                    <div class="row mb-3">
                        <div class="col-6">
                            <label class="form-label fw-bold">Giá bán</label>
                            <input type="number" name="price" class="form-control" required>
                        </div>
                        <div class="col-6">
                            <label class="form-label fw-bold">Số lượng</label>
                            <input type="number" name="unit_in_stock" class="form-control" required>
                        </div>
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-bold">Hình ảnh</label>
                        <input type="file" name="image" class="form-control" accept="image/*" required>
                    </div>
                    <button type="submit" class="btn btn-save w-100 py-2 fw-bold">Lưu sản phẩm</button>
                    <a href="/" class="d-block text-center mt-3 text-decoration-none text-muted">Hủy bỏ</a>
                </form>
            </div>
        </div>
    </div>
</body>

</html>