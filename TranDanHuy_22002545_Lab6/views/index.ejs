<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <title>Danh sách Sản phẩm - Quản lý Kho</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        body {
            background-color: #f0f2f5;
            color: #333;
        }
        
        .main-card {
            background: white;
            border-radius: 12px;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.05);
            overflow: hidden;
            border: 2px solid #adb5bd;
            /* Khung bảng rõ ràng */
        }
        
        .table-header {
            background-color: #1a237e;
            /* Màu xanh Navy chuyên nghiệp */
            color: white;
        }
        /* Kẻ lưới bảng sắc nét cho từng ô để phân biệt dữ liệu */
        
        .table th,
        .table td {
            border: 1px solid #dee2e6 !important;
            vertical-align: middle;
            text-align: center;
            padding: 12px !important;
        }
        
        .table tr:hover {
            background-color: #f8faff;
            /* Hiệu ứng di chuột */
        }
        
        .search-container {
            border-radius: 25px;
            background: white;
            border: 1px solid #adb5bd;
            padding: 2px 15px;
        }
        
        .product-img {
            border-radius: 5px;
            border: 1px solid #ddd;
            object-fit: cover;
        }
        
        .btn-action {
            border-radius: 6px;
        }
    </style>
</head>

<body>
    <div class="container py-5">
        <div class="d-flex justify-content-between align-items-end mb-4">
            <div>
                <h2 class="fw-bold mb-0">Kho Sản phẩm</h2>

            </div>
            <div class="d-flex gap-3">
                <form action="/" method="GET" class="search-container d-flex align-items-center">
                    <i class="bi bi-search text-muted me-2"></i>
                    <input type="text" name="search" class="form-control border-0 shadow-none bg-transparent" placeholder="Tìm tên..." value="<%= typeof searchTerm !== 'undefined' ? searchTerm : '' %>" style="width: 180px;">

                    <% if(typeof searchTerm !== 'undefined' && searchTerm !== "") { %>
                        <a href="/" class="btn btn-link text-muted p-0 ms-2" title="Xóa tìm kiếm">
                            <i class="bi bi-x-circle-fill"></i>
                        </a>
                        <% } %>
                </form>
                <a href="/add" class="btn btn-dark px-4 shadow-sm" style="background-color: #1a237e;">
                    <i class="bi bi-plus-lg me-2"></i>Thêm mới
                </a>
            </div>
        </div>

        <% if(typeof message !== 'undefined' && message) { %>
            <div class="alert alert-success alert-dismissible fade show border-start border-success border-4 shadow-sm" role="alert">
                <i class="bi bi-check-circle-fill me-2"></i>
                <%= message %>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
            <% } %>

                <div class="main-card">
                    <table class="table table-bordered mb-0">
                        <thead class="table-header text-white">
                            <tr>
                                <th>MÃ</th>
                                <th>HÌNH ẢNH</th>
                                <th>TÊN SẢN PHẨM</th>
                                <th>GIÁ BÁN</th>
                                <th>TỒN KHO</th>
                                <th>THAO TÁC</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (products.length > 0) { %>
                                <% products.forEach(p => { %>
                                    <tr>
                                        <td class="small text-muted font-monospace">
                                            <%= p.id.substring(0,8) %>
                                        </td>
                                        <td>
                                            <img src="<%= p.url_image %>" class="product-img" width="55" height="55">
                                        </td>
                                        <td class="fw-bold text-dark">
                                            <%= p.name %>
                                        </td>
                                        <td class="text-primary fw-bold">
                                            <%= Number(p.price).toLocaleString() %> VNĐ
                                        </td>
                                        <td>
                                            <% if(p.unit_in_stock > 10) { %>
                                                <span class="badge bg-success-subtle text-success border border-success px-3 py-2">
                                            <%= p.unit_in_stock %> sản phẩm
                                        </span>
                                                <% } else { %>
                                                    <span class="badge bg-danger text-white px-3 py-2">
                                            Chỉ còn <%= p.unit_in_stock %>
                                        </span>
                                                    <% } %>
                                        </td>
                                        <td>
                                            <div class="d-flex justify-content-center gap-2">
                                                <a href="/detail/<%= p.id %>" class="btn btn-sm btn-outline-primary btn-action px-3">Xem chi tiết</a>
                                                <a href="/edit/<%= p.id %>" class="btn btn-sm btn-outline-warning btn-action text-dark"><i class="bi bi-pencil"></i></a>
                                                <a href="/delete/<%= p.id %>" class="btn btn-sm btn-outline-danger btn-action" onclick="return confirm('Bạn có chắc chắn muốn xóa?')"><i class="bi bi-trash"></i></a>
                                            </div>
                                        </td>
                                    </tr>
                                    <% }) %>
                                        <% } else { %>
                                            <tr>
                                                <td colspan="6" class="py-5 text-muted">Không tìm thấy sản phẩm nào phù hợp.</td>
                                            </tr>
                                            <% } %>
                        </tbody>
                    </table>
                </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>