<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <title>Chi tiết sản phẩm</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background-color: #f0f2f5;
        }
        
        .detail-card {
            border: 1px solid #adb5bd;
            border-radius: 20px;
            overflow: hidden;
            background: white;
        }
        
        .img-section {
            border-right: 1px solid #dee2e6;
            padding: 50px;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        
        .price-text {
            font-size: 2.5rem;
            color: #1a237e;
            font-weight: 800;
        }
    </style>
</head>

<body>
    <div class="container py-5 mt-5">
        <div class="detail-card shadow-lg mx-auto" style="max-width: 900px;">
            <div class="row g-0">
                <div class="col-md-5 img-section">
                    <img src="<%= product.url_image %>" class="img-fluid rounded shadow" style="max-height: 400px;">
                </div>
                <div class="col-md-7 p-5">
                    <p class="text-muted small fw-bold">MÃ SẢN PHẨM: #
                        <%= product.id %>
                    </p>
                    <h1 class="fw-bold text-dark mb-4">
                        <%= product.name %>
                    </h1>
                    <div class="price-text mb-4">
                        <%= Number(product.price).toLocaleString() %> VNĐ</div>
                    <div class="mb-5">
                        <span class="badge bg-light text-primary border border-primary px-3 py-2 fs-6">Trong kho: <%= product.unit_in_stock %> cái</span>
                    </div>
                    <div class="d-flex gap-3">
                        <a href="/" class="btn btn-outline-secondary btn-lg px-4 rounded-pill">Quay lại</a>
                        <a href="/edit/<%= product.id %>" class="btn btn-primary btn-lg px-5 rounded-pill shadow-sm" style="background-color: #1a237e;">Chỉnh sửa</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>

</html>