<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Products CRUD (DynamoDB)</title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <main class="container">

      <div class="layout">
        <aside class="form-box">
          <h2>Thêm Sản phẩm mới</h2>
          <form action="/products" method="post">
            <label>ID (tùy chọn):<input type="text" name="id" placeholder="(Ví dụ: P01)"></label>
            <label>Tên sản phẩm:<input type="text" name="name" required></label>
            <label>Giá:<input type="number" name="price" step="0.01" required></label>
            <label>URL hình ảnh:<input type="text" name="url_image" placeholder="https://..."></label>
            <button class="btn-primary" type="submit">Lưu sản phẩm</button>
          </form>
        </aside>

        <section class="list-box">
          <h2>Danh sách sản phẩm</h2>
          <table class="product-table">
            <thead>
              <tr>
                <th>ID</th>
                <th>Ảnh</th>
                <th>Tên sản phẩm</th>
                <th>Giá</th>
                <th>Thao tác</th>
              </tr>
            </thead>
            <tbody>
              <% products.forEach(p => { %>
                <tr>
                  <td><%= p.id %></td>
                  <td>
                    <% if (p.url_image) { %>
                      <img src="<%= p.url_image %>" alt="img" class="thumb-small">
                    <% } %>
                  </td>
                  <td><%= p.name %></td>
                  <td><%= p.price %> VNĐ</td>
                  <td>
                    <a class="link-edit" href="/products/<%= p.id %>/edit">Sửa</a>
                    <form action="/products/<%= p.id %>/delete" method="post" style="display:inline">
                      <button class="link-delete" type="submit" onclick="return confirm('Xóa hả bro?')">Xóa</button>
                    </form>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </section>
      </div>
    </main>
  </body>
</html>
